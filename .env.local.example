# Salin file ini jadi ".env.local" (jangan di-commit, sudah masuk .gitignore)
# supaya "npm run dev" di local memakai project Supabase TERPISAH dari versi
# online -- data uji coba tidak akan tercampur/mengubah data asli.
#
# Cara membuat project Supabase khusus dev/staging:
# 1. Buka https://supabase.com/dashboard -> New Project (gratis).
# 2. Jalankan ulang migration yang ada di folder supabase/migrations/ pada
#    project baru ini (SQL Editor -> tempel isi tiap file migrasi urut sesuai
#    nama file).
# 3. Buka Project Settings -> API, salin "Project URL" dan "anon public key"
#    ke bawah ini.
#
# Kalau file .env.local TIDAK dibuat, "npm run dev" akan otomatis memakai
# project produksi (perilaku sebelumnya) -- jadi WAJIB isi ini kalau ingin
# uji coba benar-benar terpisah dari data online.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
